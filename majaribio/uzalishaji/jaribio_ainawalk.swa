husisha C::stdio
husisha "../../msingi/msambazaji.swa"
husisha "../../msingi/uzalishaji.swa"

N32 main(N32 argc, N8** argv) {
    // Build minimal AST: PROGRAMU wrapping nothing
    N32 prog = node_mpya(AST_PROGRAMU, 0, -1, -1);

    andika("; Kabla ya uzalishaji_kuu...\n");
    uzalishaji_kuu();
    andika("; Baada ya kichwa, kabla ya uzalishaji_aina_walk...\n");
    uzalishaji_aina_walk(prog);
    andika("; Baada ya uzalishaji_aina_walk.\n");
    rudisha 0;
}
